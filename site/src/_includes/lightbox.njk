<!-- Lightbox: any img.zoomable opens here at full size. Closes on backdrop click, ✕, or Esc. -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Enlarged screenshot" hidden>
  <button class="lightbox-close" type="button" aria-label="Close">&times;</button>
  <img class="lightbox-img" src="" alt="" />
</div>
<script>
  (function () {
    const box = document.getElementById('lightbox');
    const img = box.querySelector('.lightbox-img');
    let lastFocus = null;

    const close = () => {
      box.hidden = true;
      img.removeAttribute('src');
      document.documentElement.style.overflow = '';
      if (lastFocus) lastFocus.focus();
    };
    const open = (source, alt) => {
      lastFocus = document.activeElement;
      img.src = source;
      img.alt = alt || '';
      box.hidden = false;
      document.documentElement.style.overflow = 'hidden';
      box.querySelector('.lightbox-close').focus();
    };

    for (const el of document.querySelectorAll('img.zoomable')) {
      el.addEventListener('click', () => open(el.currentSrc || el.src, el.alt));
    }
    // Click the dimmed backdrop (but not the image) to close.
    box.addEventListener('click', (event) => {
      if (event.target === box) close();
    });
    box.querySelector('.lightbox-close').addEventListener('click', close);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !box.hidden) close();
    });
  })();
</script>
